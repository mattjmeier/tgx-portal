# Plane stack bootstrap environment
#
# Copy this file to `.env` in the same directory before running `docker compose up -d`.
# Replace the passwords and keys before using anything beyond local bootstrap.

PLANE_POSTGRES_USER=plane
PLANE_POSTGRES_PASSWORD=change-me
PLANE_POSTGRES_DB=plane

PLANE_RABBITMQ_USER=plane
PLANE_RABBITMQ_PASSWORD=change-me
PLANE_RABBITMQ_VHOST=plane

PLANE_AWS_REGION=
PLANE_AWS_ACCESS_KEY_ID=access-key
PLANE_AWS_SECRET_ACCESS_KEY=change-me
PLANE_AWS_S3_BUCKET_NAME=uploads

PLANE_FILE_SIZE_LIMIT=5242880
PLANE_TRUSTED_PROXIES=0.0.0.0/0
PLANE_SITE_ADDRESS=:80
PLANE_CERT_ACME_CA=https://acme-v02.api.letsencrypt.org/directory
PLANE_CERT_EMAIL=
PLANE_CERT_ACME_DNS=
PLANE_MINIO_ENDPOINT_SSL=0
PLANE_API_KEY_RATE_LIMIT=60/minute

# Exposed Plane proxy ports on the host.
PLANE_HTTP_PORT=8088
PLANE_HTTPS_PORT=8443
