POSTGRES_DB=tgx_portal
POSTGRES_USER=tgx_portal
POSTGRES_PASSWORD=tgx_portal

DIRECTUS_KEY=replace-me-with-a-long-random-string
DIRECTUS_SECRET=replace-me-with-an-even-longer-random-string
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=change-me-now
DIRECTUS_CORS_ENABLED=true
DIRECTUS_PUBLIC_URL=http://localhost:8055

VITE_DIRECTUS_URL=http://localhost:8055

# Automation API token (STORY-003)
# Create a Directus user with the `System` role and generate a static access token
# for it. This token is used by Directus Flows when calling internal endpoints
# like `/plane-sync/sync` (so those endpoints don't need to be public).
DIRECTUS_AUTOMATION_TOKEN=

# Plane integration (STORY-001)
# Prefer using a webhook-style integration URL so Directus can call out without
# hard-coding Plane API semantics in this repo.
PLANE_WEBHOOK_URL=
# Optional: default workspace name if mapping doesn't match.
PLANE_WORKSPACE_DEFAULT=
# Optional: JSON map from normalized pi_name -> workspace, e.g.
# {"dr jane doe":"workspace-a","dr john smith":"workspace-b"}
PLANE_WORKSPACE_MAP_JSON=
